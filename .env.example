# Required: get from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=123456:ABC-DEF...

# Optional: CoinGecko Pro API key (raises rate limits ~30/min -> 500/min)
# Leave blank to use the free public API.
COINGECKO_API_KEY=

# Optional: Etherscan V2 API key — powers /wallet 0x… and /gas. Free
# key at https://etherscan.io/apis. One key works across all 60+
# Etherscan-family chains via the V2 multichain API; the bot uses
# Ethereum, BSC, Polygon, Arbitrum, Optimism, Base and Avalanche.
# Leave blank to disable /wallet and /gas.
ETHERSCAN_API_KEY=

# Optional: Premium custom-emoji IDs for the /ath card, /wallet card
# and /gas card. Discover an ID by sending the Premium emoji in DM and
# replying with /emojiid. Leaving any blank falls back to the plain
# emoji shown in the comments below. The bot must be sent by a Premium
# account for these to render at all in the recipient's client.
#
# /ath
PREMIUM_EMOJI_ATH_HEADER_ID=  # 🏆 — header
PREMIUM_EMOJI_DIAMOND_ID=     # 💎 — Current price + wallet Balance
PREMIUM_EMOJI_ATH_UP_ID=      # 🚀 — ATH section header
PREMIUM_EMOJI_ATH_DOWN_ID=    # 🩸 — ATL section
PREMIUM_EMOJI_DATE_ID=        # 📅 — calendar date
PREMIUM_EMOJI_PCT_DOWN_ID=    # 📉 — "% from ATH"
PREMIUM_EMOJI_ATL_GAIN_ID=    # 🚀 — "% from ATL" gain row (defaults to ATH_UP if empty)
# /wallet
PREMIUM_EMOJI_WALLET_ID=      # 🔍 — wallet header
PREMIUM_EMOJI_CLOCK_ID=       # 🕐 — recent transactions
# /gas
PREMIUM_EMOJI_GAS_ID=         # ⛽ — gas header

# Optional: comma-separated list of Telegram chat IDs the bot is allowed to
# respond in (for free-text symbol triggers). Leave blank to allow everywhere.
ALLOWED_CHAT_IDS=

# Branding (shown on the chart watermark and message footer)
BRAND_NAME=Zeenova
TELEGRAM_CHANNEL_URL=https://t.me/ox_zeen
TELEGRAM_GROUP_URL=https://t.me/blockzeen

# Logging
LOG_LEVEL=INFO
