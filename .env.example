# Required: get from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=123456:ABC-DEF...

# Optional: CoinGecko Pro API key (raises rate limits ~30/min -> 500/min)
# Leave blank to use the free public API.
COINGECKO_API_KEY=

# Optional: Etherscan V2 API key — powers /wallet 0x… (Ethereum wallet
# summary). Free key at https://etherscan.io/apis. One key works across
# all 60+ Etherscan-family chains via the V2 multichain API. Leave
# blank to disable the /wallet command.
ETHERSCAN_API_KEY=

# Optional: comma-separated list of Telegram chat IDs the bot is allowed to
# respond in (for free-text symbol triggers). Leave blank to allow everywhere.
ALLOWED_CHAT_IDS=

# Branding (shown on the chart watermark and message footer)
BRAND_NAME=Zeenova
TELEGRAM_CHANNEL_URL=https://t.me/ox_zeen
TELEGRAM_GROUP_URL=https://t.me/blockzeen

# Logging
LOG_LEVEL=INFO
